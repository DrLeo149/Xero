# ----------------------------------------------------------------------------
# Copy this file to `backend/.env` and fill in real values. Never commit .env.
# ----------------------------------------------------------------------------

# Xero API credentials (from developer.xero.com)
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:3000/api/xero/callback

# Xero OAuth scopes (space-separated)
XERO_SCOPES=openid profile email offline_access accounting.transactions.read accounting.contacts.read accounting.reports.read accounting.settings.read

# Database
# Local dev: SQLite file
DATABASE_URL="file:./dev.db"
# Production (Railway): postgresql://user:pass@host:port/db

# JWT signing secret (generate with: openssl rand -hex 64)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Initial admin account seeded on first boot
SEED_ADMIN_EMAIL=meghana@ankyadvisors.com
SEED_ADMIN_PASSWORD=change-me-on-first-login

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
